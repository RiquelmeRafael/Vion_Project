# Ignore external libraries (Bootstrap, jQuery, etc.)
Vion.Web/wwwroot/lib/** linguist-vendored

# Ensure CSS and JS are visible in stats
Vion.Web/wwwroot/css/** linguist-detectable=true
Vion.Web/wwwroot/js/** linguist-detectable=true

# EXCLUDE Migrations from stats to prevent C# from reaching 99%
# This allows HTML, CSS, and JS to have a larger percentage share
Vion.Infrastructure/Migrations/** linguist-generated=true

# Treat Razor Views as HTML to boost the HTML statistic
*.cshtml linguist-language=HTML
