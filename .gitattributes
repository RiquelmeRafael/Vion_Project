# Ignore external libraries
Vion.Web/wwwroot/lib/** linguist-vendored

# Force Razor Views to be counted as C# to reflect backend nature
*.cshtml linguist-language=C#

# Keep custom assets visible (but they will be smaller in proportion now)
Vion.Web/wwwroot/css/** linguist-detectable=true
Vion.Web/wwwroot/js/** linguist-detectable=true
