<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VION</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body class="bg-dark text-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-black">
        <div class="container">
            <a class="navbar-brand fw-bold"
               asp-area=""
               asp-controller="Home"
               asp-action="Index">
                VION
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto align-items-center gap-2">

                    <!-- PÚBLICO -->
                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area=""
                           asp-controller="Home"
                           asp-action="Index">
                            Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area=""
                           asp-controller="Home"
                           asp-action="Catalog">
                            Produtos
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area=""
                           asp-controller="Home"
                           asp-action="About">
                            Sobre
                        </a>
                    </li>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <!-- ADMIN -->
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-semibold"
                                   asp-area="Admin"
                                   asp-controller="Dashboard"
                                   asp-action="Index">
                                    Dashboard
                                </a>
                            </li>
                        }

                        <!-- ADMIN OU GERENTE -->
                        @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-info fw-semibold"
                                   asp-area="Admin"
                                   asp-controller="Manage"
                                   asp-action="Index">
                                    Gerenciar
                                </a>
                            </li>
                        }

                        <li class="nav-item text-light ms-3">
                            Olá, <strong>@User.Identity.Name</strong>
                        </li>

                        <li class="nav-item">
                            <form asp-area=""
                                  asp-controller="Auth"
                                  asp-action="Logout"
                                  method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Sair
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-area=""
                               asp-controller="Auth"
                               asp-action="Login">
                                Entrar
                            </a>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        @RenderBody()
    </div>

    <footer class="text-center py-4 text-secondary">
        <small>© @DateTime.Now.Year Vion — All rights reserved</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
